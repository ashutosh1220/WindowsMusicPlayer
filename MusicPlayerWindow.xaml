<Window
    x:Class="WinUIMusicPlayer.MusicPlayerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUIMusicPlayer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Crystal Player"
    SizeChanged="Window_SizeChanged"
    Closed="Window_Closed">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Image x:Name="BackgroundImage"
               Source="ms-appx:///Assets/blur_bg.jpg"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"/>

        <Rectangle x:Name="GlassScrim"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CC0A0A12" Offset="0.0"/>
                    <GradientStop Color="#B20C0C1A" Offset="1.0"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border x:Name="GlassBorderLayer"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4000F5FF" Offset="0.0"/>
                    <GradientStop Color="#20A855F7" Offset="0.5"/>
                    <GradientStop Color="#10EC4899" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" x:Name="AppTitleBar" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnOpenSidebar"
                        Grid.Column="0"
                        Width="40" Height="40"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#3000F5FF"
                        CornerRadius="1"
                        Margin="8,4,4,4"
                        Padding="0"
                        Click="BtnOpenSidebar_Click"
                        ToolTipService.ToolTip="Open Playlist">
                    <FontIcon Glyph="&#xE700;"
                              FontSize="16"
                              Foreground="#00F5FF"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Button>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="6,0,0,0"
                            Spacing="8">
                    <FontIcon Glyph="&#xE8D6;" FontSize="16" Foreground="#00F5FF"/>
                    <TextBlock x:Name="TitleBarText"
                               Text="MUSIC PLAYER"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#E0E0FF"
                               VerticalAlignment="Center"
                               CharacterSpacing="150"/>
                </StackPanel>

                <Border Grid.Column="2" Background="Transparent"/>
            </Grid>

            <Grid Grid.Row="1">

                <Grid x:Name="PlayerPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Album Art + Song Info -->
                    <Grid Grid.Row="0" VerticalAlignment="Center">

                        <Canvas x:Name="AlbumRippleCanvas"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="400" Height="400"
                                IsHitTestVisible="False"/>

                        <Border x:Name="AlbumOuterBorder"
                                Width="220" Height="220"
                                CornerRadius="110"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="3"
                                BorderThickness="2">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6000F5FF" Offset="0.0"/>
                                    <GradientStop Color="#60A855F7" Offset="0.5"/>
                                    <GradientStop Color="#60EC4899" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00F5FF" Offset="0.0"/>
                                    <GradientStop Color="#A855F7" Offset="0.5"/>
                                    <GradientStop Color="#EC4899" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Border x:Name="AlbumInnerBorder"
                                    CornerRadius="107"
                                    Background="#1E1E2E"
                                    BorderThickness="1.5"
                                    BorderBrush="#40FFFFFF">
                                <Image x:Name="AlbumArt"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </Border>

                        <StackPanel x:Name="SongInfoPanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,300,0,0">
                            <Border CornerRadius="12"
                                    Padding="16,8"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="Transparent"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4000F5FF" Offset="0"/>
                                        <GradientStop Color="#20A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel>
                                    <TextBlock x:Name="LblSongTitle"
                                               Text="Select a Song"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#F0F0FF"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="320"/>
                                    <TextBlock x:Name="LblArtistName"
                                               Text="Artist"
                                               FontSize="13"
                                               Foreground="#00F5FF"
                                               TextAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            x:Name="ControlsPanel"
                            CornerRadius="4,4,0,0"
                            Padding="20,14,20,20"
                            BorderThickness="1,1,1,0">
                        <Border.Background>
                            <SolidColorBrush Color="#CC141420"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5000F5FF" Offset="0.0"/>
                                <GradientStop Color="#30A855F7" Offset="0.5"/>
                                <GradientStop Color="#20EC4899" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>

                        <StackPanel x:Name="ControlsStack" Spacing="10">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="LblTimeElapsed"
                                           Grid.Column="0"
                                           Text="0:00"
                                           Foreground="#B3B3B3"
                                           FontSize="11"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"/>

                                <Grid Grid.Column="1" Height="24" Margin="4,0">
                                    <Border Height="4"
                                            CornerRadius="0"
                                            BorderThickness="0.5"
                                            BorderBrush="#4000F5FF"
                                            Background="#2AFFFFFF"
                                            VerticalAlignment="Center"/>
                                    <Border x:Name="ProgressFill"
                                            Height="4"
                                            CornerRadius="0"
                                            Background="#00F5FF"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            VerticalAlignment="Center"/>
                                    <Ellipse x:Name="ProgressThumb"
                                             Width="14" Height="14"
                                             Fill="#00F5FF"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Margin="-7,0,0,0"/>
                                    <Ellipse x:Name="ProgressThumbRing"
                                             Width="18" Height="18"
                                             Stroke="#4000F5FF"
                                             StrokeThickness="1"
                                             Fill="Transparent"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Margin="-9,0,0,0"/>
                                    <Rectangle x:Name="ProgressHitTarget"
                                               Fill="Transparent"
                                               Tapped="ProgressBar_Tapped"
                                               ManipulationMode="TranslateX"
                                               ManipulationDelta="ProgressBar_ManipulationDelta"/>
                                </Grid>

                                <TextBlock x:Name="LblTimeTotal"
                                           Grid.Column="2"
                                           Text="0:00"
                                           Foreground="#B3B3B3"
                                           FontSize="11"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                            </Grid>

                            <StackPanel x:Name="TransportPanel"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="12">

                                <Border x:Name="ShuffleBorder"
                                        Width="38" Height="38"
                                        CornerRadius="19"
                                        BorderThickness="1"
                                        BorderBrush="#30808080"
                                        Background="Transparent">
                                    <Button x:Name="BtnShuffle"
                                            Width="38" Height="38"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="19"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BtnShuffle_Click"
                                            ToolTipService.ToolTip="Shuffle">
                                        <FontIcon x:Name="ShuffleIcon"
                                                  Glyph="&#xE14C;"
                                                  FontSize="16"
                                                  Foreground="#808080"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>
                                </Border>

                                <Border x:Name="PrevBorder"
                                        Width="44" Height="44"
                                        CornerRadius="22"
                                        BorderThickness="1"
                                        BorderBrush="#4000F5FF"
                                        Background="#2A2A3E">
                                    <Button x:Name="BtnPrev"
                                            Width="44" Height="44"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="22"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BtnPrev_Click"
                                            ToolTipService.ToolTip="Previous">
                                        <FontIcon x:Name="PrevIcon"
                                                  Glyph="&#xE892;"
                                                  FontSize="18"
                                                  Foreground="#E0E0FF"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>
                                </Border>

                                <Border x:Name="PlayBtnBorder"
                                        Width="60" Height="60"
                                        CornerRadius="30"
                                        BorderThickness="2"
                                        Background="#00D4E8">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="Transparent" Offset="0.0"/>
                                            <GradientStop Color="Transparent" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Button x:Name="BtnPlayPause"
                                            Width="60" Height="60"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="30"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BtnPlayPause_Click"
                                            ToolTipService.ToolTip="Play/Pause">
                                        <FontIcon x:Name="PlayPauseIcon"
                                                  Glyph="&#xE768;"
                                                  FontSize="24"
                                                  Foreground="#0F0F0F"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>
                                </Border>

                                <Border x:Name="NextBorder"
                                        Width="44" Height="44"
                                        CornerRadius="22"
                                        BorderThickness="1"
                                        BorderBrush="#4000F5FF"
                                        Background="#2A2A3E">
                                    <Button x:Name="BtnNext"
                                            Width="44" Height="44"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="22"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BtnNext_Click"
                                            ToolTipService.ToolTip="Next">
                                        <FontIcon x:Name="NextIcon"
                                                  Glyph="&#xE893;"
                                                  FontSize="18"
                                                  Foreground="#E0E0FF"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>
                                </Border>

                                <Border x:Name="RepeatBorder"
                                        Width="38" Height="38"
                                        CornerRadius="19"
                                        BorderThickness="1"
                                        BorderBrush="#30808080"
                                        Background="Transparent">
                                    <Button x:Name="BtnRepeat"
                                            Width="38" Height="38"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="19"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BtnRepeat_Click"
                                            ToolTipService.ToolTip="Repeat">
                                        <FontIcon x:Name="RepeatIcon"
                                                  Glyph="&#xE8EE;"
                                                  FontSize="16"
                                                  Foreground="#808080"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>
                                </Border>
                            </StackPanel>

                            <Border x:Name="VolumeSpeedBorder"
                                    CornerRadius="1"
                                    Padding="10,8"
                                    BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush Color="#221A1A2E"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#3000F5FF"/>
                                </Border.BorderBrush>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Button x:Name="BtnVolume"
                                                Width="32" Height="32"
                                                Background="Transparent"
                                                BorderThickness="1"
                                                BorderBrush="#3000F5FF"
                                                CornerRadius="16"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Click="BtnVolume_Click">
                                            <FontIcon x:Name="VolumeIcon"
                                                      Glyph="&#xE767;"
                                                      FontSize="14"
                                                      Foreground="#00F5FF"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Button>
                                        <Grid x:Name="VolumeBarGrid" Width="110" Height="24">
                                            <Border Height="4"
                                                    CornerRadius="2"
                                                    BorderThickness="0.5"
                                                    BorderBrush="#3000F5FF"
                                                    Background="#2AFFFFFF"
                                                    VerticalAlignment="Center"/>
                                            <Border x:Name="VolumeFill"
                                                    Height="4"
                                                    CornerRadius="2"
                                                    Background="#00F5FF"
                                                    HorizontalAlignment="Left"
                                                    Width="77"
                                                    VerticalAlignment="Center"/>
                                            <Rectangle Fill="Transparent"
                                                       Tapped="VolumeBar_Tapped"
                                                       ManipulationMode="TranslateX"
                                                       ManipulationDelta="VolumeBar_ManipulationDelta"/>
                                            <Ellipse x:Name="VolumeThumb"
                                                     Width="12" Height="12"
                                                     Fill="#00F5FF"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Center"
                                                     Margin="-6,0,0,0"/>
                                        </Grid>
                                        <TextBlock x:Name="LblVolPct"
                                                   Text="70%"
                                                   Foreground="#00F5FF"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="SpdLabel"
                                                   Text="SPD"
                                                   Foreground="#808080"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   CharacterSpacing="100"/>
                                        <Slider x:Name="TrkSpeed"
                                                Width="72"
                                                Minimum="0.5" Maximum="2.0" Value="1.0"
                                                StepFrequency="0.1"
                                                ValueChanged="TrkSpeed_ValueChanged"/>
                                        <TextBlock x:Name="LblSpeedDisplay"
                                                   Text="1.0x"
                                                   Foreground="#00F5FF"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>
                </Grid>

                <Rectangle x:Name="SidebarScrim"
                           Fill="#80000000"
                           Tapped="SidebarScrim_Tapped"
                           Visibility="Collapsed"
                           IsHitTestVisible="True"/>

                <Border x:Name="SidebarPanel"
                        Width="320"
                        CornerRadius="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderThickness="0,1,1,1">
                    <Border.Background>
                        <SolidColorBrush Color="#EE0C0C18"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#6000F5FF" Offset="0.0"/>
                            <GradientStop Color="#30A855F7" Offset="0.5"/>
                            <GradientStop Color="#10EC4899" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.RenderTransform>
                        <CompositeTransform x:Name="SidebarTransform" TranslateX="-340"/>
                    </Border.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">

                            <Grid Padding="16,14,12,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8FD;"
                                              FontSize="14"
                                              Foreground="#00F5FF"/>
                                    <TextBlock Text="PLAYLIST"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#00F5FF"
                                               VerticalAlignment="Center"
                                               CharacterSpacing="150"/>
                                </StackPanel>

                                <Button x:Name="BtnScanMusicSidebar"
                                        Grid.Column="1"
                                        Width="35" Height="35"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="#3000F5FF"
                                        CornerRadius="20"
                                        Margin="0,0,10,0"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Click="BtnScanMusic_Click"
                                        ToolTipService.ToolTip="Open Music Folder">
                                    <FontIcon Glyph="&#xE8B7;"
                                              FontSize="14"
                                              Foreground="#A855F7"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>

                                <Button x:Name="BtnCloseSidebar"
                                        Grid.Column="2"
                                        Width="35" Height="35"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="#3000F5FF"
                                        CornerRadius="20"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Click="BtnCloseSidebar_Click"
                                        ToolTipService.ToolTip="Close">
                                    <FontIcon Glyph="&#xE711;"
                                              FontSize="14"
                                              Foreground="#B3B3B3"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <Border Height="1"
                                    VerticalAlignment="Bottom">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6000F5FF" Offset="0.0"/>
                                        <GradientStop Color="#00A855F7" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                        </Grid>

                        <TextBlock x:Name="LblScanStatus"
                                   Grid.Row="1"
                                   Text=""
                                   Foreground="#808080"
                                   FontSize="10"
                                   Margin="16,6,16,0"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="Collapsed"/>

                        <Border Grid.Row="2"
                                Margin="12,10,12,6"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#4000F5FF">
                            <TextBox x:Name="TxtSearch"
                                     PlaceholderText="Search songs..."
                                     Padding="10,8"
                                     Background="#1A1A2E"
                                     Foreground="#E0E0FF"
                                     PlaceholderForeground="#606080"
                                     BorderThickness="0"
                                     CornerRadius="8"
                                     FontSize="13"
                                     TextChanged="TxtSearch_TextChanged"/>
                        </Border>

                        <ListView x:Name="PlaylistView"
                                  Grid.Row="3"
                                  Background="Transparent"
                                  SelectionMode="Single"
                                  SelectionChanged="PlaylistView_SelectionChanged"
                                  Padding="8,0,8,12">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="CornerRadius" Value="4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TrackRowBorder"
                                            CornerRadius="4"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Background="#0DFFFFFF">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3500F5FF" Offset="0.0"/>
                                                <GradientStop Color="#25A855F7" Offset="0.5"/>
                                                <GradientStop Color="#15EC4899" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="34" Height="34"
                                                    CornerRadius="4"
                                                    Background="#12FFFFFF"
                                                    BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6000F5FF" Offset="0.0"/>
                                                        <GradientStop Color="#50A855F7" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <FontIcon Glyph="&#xE8D6;"
                                                          FontSize="14"
                                                          Foreground="#00F5FF"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,6,0"
                                                        VerticalAlignment="Center"
                                                        Spacing="2">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#EEEEFF"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}"
                                                           Foreground="#6060A0"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Padding="6,2"
                                                    CornerRadius="3"
                                                    Background="#0A00F5FF"
                                                    BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#4000F5FF" Offset="0.0"/>
                                                        <GradientStop Color="#30EC4899" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <TextBlock Text="{Binding Duration}"
                                                           Foreground="#4080C0"
                                                           FontSize="10"
                                                           FontFamily="Consolas"/>
                                            </Border>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>